# ==========================================
# 1. Rust / Cargo (Ignores the debug/release build artifacts)
# ==========================================
# Cargo tracks builds in a directory named 'target' by default
**/*.rs.bk
**/target/

# ==========================================
# 2. Flutter & Dart (Ignores .dart_tool, .packages, etc.)
# ==========================================
.dart_tool/
.packages
.pub-cache/
.pub/
build/

# If flutter_rust_bridge generates specific temporary files
# add them here (e.g., bridge_generated.web.js)

# ==========================================
# 3. Python (For your backend-web folder)
# ==========================================
**/.venv/
backend-web/.env

# ==========================================
# 4. IDEs and System Dotfiles (The "dot files")
# ==========================================
# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# VS Code files
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IntelliJ / Android Studio files
.idea/
*.iml
*.iws

# Local environment variables (secrets)
.env
.env.local


# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
